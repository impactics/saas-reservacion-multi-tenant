generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIAL_REFUND
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  REMINDER_24H
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  CALENDAR
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ─────────────────────────────────────────────
// ORGANIZATION
// ─────────────────────────────────────────────

model Organization {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  name                  String
  description           String?
  logoUrl               String?  @map("logo_url")
  primaryColor          String?  @map("primary_color")
  phoneWhatsapp         String?  @map("phone_whatsapp")
  timezone              String   @default("America/Guayaquil")
  googleCalendarEnabled Boolean  @default(false) @map("google_calendar_enabled")
  whatsappEnabled       Boolean  @default(false) @map("whatsapp_enabled")

  // Política de cancelación
  // Horas antes de la cita para reembolso total (default 24h)
  cancelFullRefundHours    Int  @default(24)  @map("cancel_full_refund_hours")
  // Horas antes de la cita para reembolso parcial (default 12h)
  cancelPartialRefundHours Int  @default(12)  @map("cancel_partial_refund_hours")
  // Porcentaje de reembolso parcial 0–100 (default 50%)
  cancelPartialRefundPct   Int  @default(50)  @map("cancel_partial_refund_pct")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  professionals    Professional[]
  services         Service[]
  bookings         Booking[]
  notificationJobs NotificationJob[]
  patients         Patient[]

  @@map("organizations")
}

// ─────────────────────────────────────────────
// PATIENT  (identidad del paciente por teléfono)
// ─────────────────────────────────────────────

model Patient {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  phone          String                       // E.164 sin símbolo: "593999870308"
  name           String
  email          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  otpCodes     PatientOTP[]

  // Un paciente = un teléfono por organización
  @@unique([organizationId, phone])
  @@index([organizationId])
  @@map("patients")
}

// ─────────────────────────────────────────────
// PATIENT OTP  (código temporal enviado por WhatsApp)
// ─────────────────────────────────────────────

model PatientOTP {
  id         String   @id @default(cuid())
  patientId  String   @map("patient_id")
  code       String                        // 6 dígitos
  expiresAt  DateTime @map("expires_at")   // now() + 10 min
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_otps")
}

// ─────────────────────────────────────────────
// PROFESSIONAL
// ─────────────────────────────────────────────

model Professional {
  id                  String   @id @default(cuid())
  organizationId      String   @map("organization_id")
  name                String
  email               String?
  phone               String?
  specialty           String?
  googleCalendarToken String?  @map("google_calendar_token")
  googleCalendarId    String?  @map("google_calendar_id")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt      @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  services          Service[]
  availabilityRules AvailabilityRule[]
  blackoutDates     BlackoutDate[]
  bookings          Booking[]

  @@index([organizationId])
  @@index([organizationId, active])
  @@map("professionals")
}

// ─────────────────────────────────────────────
// SERVICE
// ─────────────────────────────────────────────

model Service {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  professionalId  String   @map("professional_id")
  name            String
  description     String?
  imageUrl        String?  @map("image_url")
  durationMinutes Int      @map("duration_minutes")
  price           Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  bookings     Booking[]

  @@index([organizationId])
  @@index([professionalId])
  @@index([organizationId, active])
  @@map("services")
}

// ─────────────────────────────────────────────
// AVAILABILITY RULE
// ─────────────────────────────────────────────

model AvailabilityRule {
  id                  String   @id @default(cuid())
  organizationId      String   @map("organization_id")
  professionalId      String   @map("professional_id")
  dayOfWeek           Int      @map("day_of_week")
  startTime           String   @map("start_time")
  endTime             String   @map("end_time")
  slotDurationMinutes Int      @map("slot_duration_minutes")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt      @map("updated_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([professionalId])
  @@index([professionalId, dayOfWeek, active])
  @@map("availability_rules")
}

// ─────────────────────────────────────────────
// BLACKOUT DATE
// ─────────────────────────────────────────────

model BlackoutDate {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  professionalId String   @map("professional_id")
  date           DateTime
  startTime      String?  @map("start_time")
  endTime        String?  @map("end_time")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([professionalId])
  @@index([professionalId, date])
  @@map("blackout_dates")
}

// ─────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────

model Booking {
  id                 String        @id @default(cuid())
  organizationId     String        @map("organization_id")
  professionalId     String        @map("professional_id")
  serviceId          String        @map("service_id")

  // Relación opcional con Patient (se vincula al confirmar OTP)
  patientId          String?       @map("patient_id")

  // Datos del paciente (se guardan igual para no romper flujo guest)
  patientName        String        @map("patient_name")
  patientEmail       String?       @map("patient_email")
  patientPhone       String        @map("patient_phone")

  scheduledAt        DateTime      @map("scheduled_at")
  durationMinutes    Int           @map("duration_minutes")
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID) @map("payment_status")
  paymentId          String?       @map("payment_id")

  // Reembolso: monto en centavos aplicado al cancelar
  refundAmount       Int?          @map("refund_amount")
  refundedAt         DateTime?     @map("refunded_at")

  googleEventId      String?       @map("google_event_id")
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt      @map("updated_at")

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professional     Professional        @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service          Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  patient          Patient?            @relation(fields: [patientId], references: [id], onDelete: SetNull)
  reschedules      BookingReschedule[]
  notificationJobs NotificationJob[]

  @@index([organizationId])
  @@index([professionalId])
  @@index([serviceId])
  @@index([patientId])
  @@index([organizationId, scheduledAt])
  @@index([professionalId, scheduledAt])
  @@index([patientPhone])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// BOOKING RESCHEDULE
// ─────────────────────────────────────────────

model BookingReschedule {
  id                  String   @id @default(cuid())
  organizationId      String   @map("organization_id")
  bookingId           String   @map("booking_id")
  previousScheduledAt DateTime @map("previous_scheduled_at")
  newScheduledAt      DateTime @map("new_scheduled_at")
  reason              String?
  createdAt           DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([bookingId])
  @@map("booking_reschedules")
}

// ─────────────────────────────────────────────
// NOTIFICATION JOB
// ─────────────────────────────────────────────

model NotificationJob {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  bookingId      String              @map("booking_id")
  type           NotificationType
  channel        NotificationChannel
  status         NotificationStatus  @default(PENDING)
  scheduledFor   DateTime?           @map("scheduled_for")
  attempts       Int                 @default(0)
  lastError      String?             @map("last_error")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([bookingId])
  @@index([status, scheduledFor])
  @@map("notification_jobs")
}
