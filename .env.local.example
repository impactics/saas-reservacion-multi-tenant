# ─── Base de datos ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/saas_reservaciones"

# ─── NextAuth ────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="genera-uno-con: openssl rand -base64 32"

# ─── App URL (usada por QStash para callbacks) ───────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ─── Upstash QStash (cola de trabajos asíncronos) ────────────────
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ─── Upstash Redis (cache de slots) ──────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── WhatsApp Business Cloud API (Meta) ──────────────────────────
# Cómo obtener estos valores:
# 1. Ve a developers.facebook.com → tu app → WhatsApp → Configuración de API
# 2. PHONE_NUMBER_ID: "Identificador de número de teléfono" (ej: 1156736894180509)
# 3. API_TOKEN: el token de acceso que aparece en la sección "Token de acceso"
# 4. FROM_NUMBER: el número "De" en formato E.164 (ej: +15551800156)
WHATSAPP_API_URL="https://graph.facebook.com/v19.0/PHONE_NUMBER_ID/messages"
WHATSAPP_API_TOKEN=""
WHATSAPP_FROM_NUMBER=""

# ─── Google Calendar (opcional) ──────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
