# ─────────────────────────────────────────────────────────────────
# BASE DE DATOS — Neon PostgreSQL
# ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─────────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────────
# URL pública de la app (sin slash final)
NEXT_PUBLIC_APP_URL="https://tudominio.com"

# ─────────────────────────────────────────────────────────────────
# UPSTASH REDIS
# ─────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://YOUR_REDIS.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────────────────────────
# UPSTASH QSTASH
# ─────────────────────────────────────────────────────────────────
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ─────────────────────────────────────────────────────────────────
# GOOGLE OAUTH2 — para Google Calendar
# ─────────────────────────────────────────────────────────────────
# Crear credenciales en https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://tudominio.com/api/auth/google/callback"

# Token de verificación para el webhook push de Google Calendar
# Generar con: openssl rand -hex 32
# Pasar este token al crear el canal de notificaciones en Google Calendar API
GOOGLE_CALENDAR_WEBHOOK_TOKEN=""

# ─────────────────────────────────────────────────────────────────
# WHATSAPP — Meta Business API
# ─────────────────────────────────────────────────────────────────
# URL: https://graph.facebook.com/v19.0/{PHONE_NUMBER_ID}/messages
WHATSAPP_API_URL="https://graph.facebook.com/v19.0/PHONE_NUMBER_ID/messages"
WHATSAPP_API_TOKEN=""
WHATSAPP_FROM_NUMBER=""

# ─────────────────────────────────────────────────────────────────
# EMAIL — Resend
# ─────────────────────────────────────────────────────────────────
# Crear API key en https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="Clínica <noreply@tudominio.com>"

# ─────────────────────────────────────────────────────────────────
# AUTENTICACIÓN ADMIN — NextAuth / Auth.js
# ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://tudominio.com"
NEXTAUTH_SECRET="genera-con: openssl rand -base64 32"

# Provider Google para login admin
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─────────────────────────────────────────────────────────────────
# PAGOS — Stripe o MercadoPago
# ─────────────────────────────────────────────────────────────────
# Elegir proveedor: stripe | mercadopago
PAYMENT_PROVIDER="stripe"
# También exponer al cliente para el formulario de pago:
NEXT_PUBLIC_PAYMENT_PROVIDER="stripe"

# Stripe (https://dashboard.stripe.com/webhooks)
# El webhook secret se obtiene al registrar el endpoint en Stripe Dashboard
# o con: stripe listen --forward-to localhost:3000/api/webhooks/payment
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# MercadoPago (https://www.mercadopago.com/developers/es/docs/your-integrations/notifications/webhooks)
# El webhook secret se obtiene en la configuración de notificaciones de tu app
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
MERCADOPAGO_WEBHOOK_SECRET=""
