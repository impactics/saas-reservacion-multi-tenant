# =================================================================
# VARIABLES DE ENTORNO — saas-reservacion-multi-tenant
# =================================================================
# Copia este archivo como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# ⚠️  NUNCA comitees .env.local ni .env con valores reales.
# ⚠️  En Vercel configura estas variables en:
#     Dashboard → Project → Settings → Environment Variables
# =================================================================

# -----------------------------------------------------------------
# BASE DE DATOS — Neon PostgreSQL
# -----------------------------------------------------------------
# Obtener en: https://console.neon.tech → Connection string
# La URL de pooler (puerto 6543) se usa en runtime (Prisma Client)
# La URL directa (puerto 5432) se usa solo en migraciones
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?sslmode=require&pgbouncer=true"

# -----------------------------------------------------------------
# APP
# -----------------------------------------------------------------
# URL pública de la app (sin slash final)
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com
NEXT_PUBLIC_APP_URL="https://tudominio.com"

# -----------------------------------------------------------------
# AUTENTICACIÓN ADMIN — NextAuth / Auth.js
# -----------------------------------------------------------------
# URL de la app — requerido por NextAuth en producción
# En Vercel se puede omitir (usa VERCEL_URL automáticamente)
NEXTAUTH_URL="https://tudominio.com"

# Secret criptográfico para firmar/verificar JWT de sesión
# Generar con: openssl rand -base64 32
# ⚠️  Sin este valor la app lanza un error al arrancar (validación en lib/auth.ts)
NEXTAUTH_SECRET=""

# Provider Google OAuth para login del panel admin
# Crear en: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Redirect URI autorizado: https://tudominio.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------
# UPSTASH REDIS — Rate limiting y caché
# -----------------------------------------------------------------
# Crear instancia en: https://console.upstash.com
# Requerido por Redis.fromEnv() en middleware.ts
UPSTASH_REDIS_REST_URL="https://YOUR_REDIS.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------
# UPSTASH QSTASH — Cola de jobs asíncronos
# -----------------------------------------------------------------
# Obtener en: https://console.upstash.com → QStash → API Keys
QSTASH_TOKEN=""
# Obtener en: https://console.upstash.com → QStash → Signing Keys
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# -----------------------------------------------------------------
# GOOGLE OAUTH2 — Google Calendar (por organización)
# -----------------------------------------------------------------
# Mismas credenciales del proyecto GCP que AUTH_GOOGLE_* si usas
# el mismo OAuth client, o credenciales separadas.
# Crear en: https://console.cloud.google.com → APIs → Credentials
# Scopes requeridos: calendar.events, calendar.readonly
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Redirect URI registrado en GCP para el flujo de conexión de calendario
GOOGLE_REDIRECT_URI="https://tudominio.com/api/auth/google/callback"

# Token de verificación para el webhook push de Google Calendar
# Generar con: openssl rand -hex 32
# Pasar este token al crear el canal push en Google Calendar API
GOOGLE_CALENDAR_WEBHOOK_TOKEN=""

# -----------------------------------------------------------------
# WHATSAPP — Meta Business API (Cloud API)
# -----------------------------------------------------------------
# URL: https://graph.facebook.com/v19.0/{PHONE_NUMBER_ID}/messages
# Obtener PHONE_NUMBER_ID en: Meta for Developers → WhatsApp → Getting Started
WHATSAPP_API_URL="https://graph.facebook.com/v19.0/PHONE_NUMBER_ID/messages"
# Token de acceso permanente del sistema (no el temporal de 24h)
WHATSAPP_API_TOKEN=""
# Número de WhatsApp Business (ej: 593XXXXXXXXX)
WHATSAPP_FROM_NUMBER=""

# -----------------------------------------------------------------
# EMAIL — Resend
# -----------------------------------------------------------------
# Crear API key en: https://resend.com → API Keys
RESEND_API_KEY=""
# Dirección remitente verificada en Resend (debe coincidir con dominio verificado)
EMAIL_FROM="Clínica <noreply@tudominio.com>"

# -----------------------------------------------------------------
# PAGOS — Proveedor activo
# -----------------------------------------------------------------
# Selector de proveedor: stripe | mercadopago | payphone | paypal
PAYMENT_PROVIDER="payphone"
# Expuesto al cliente para el formulario de checkout
NEXT_PUBLIC_PAYMENT_PROVIDER="payphone"

# ── Stripe ──────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com
# Webhook secret: Stripe Dashboard → Webhooks → tu endpoint → Signing secret
#   o en desarrollo: stripe listen --forward-to localhost:3000/api/webhooks/payment
STRIPE_SECRET_KEY="sk_test_..."
# ⚠️  NEXT_PUBLIC_ obligatorio para que esté disponible en el browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── MercadoPago ─────────────────────────────────────────────────
# Dashboard: https://www.mercadopago.com/developers
# Webhook secret: Configuración → Notificaciones → Clave secreta
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
MERCADOPAGO_WEBHOOK_SECRET=""

# ── Payphone (Ecuador) ──────────────────────────────────────────
# Portal: https://appstore.payphonetodoesposible.com
# PAYPHONE_APP_ID: Token del portal (incluir el prefijo Bearer completo)
PAYPHONE_APP_ID="Bearer_xxxxx"
# PAYPHONE_TOKEN: Token de firma para verificar callbacks del webhook
# Generar con: openssl rand -hex 32
# Registrar en el portal Payphone como "Token de verificación"
PAYPHONE_TOKEN=""

# ── PayPal ──────────────────────────────────────────────────────
# Developer: https://developer.paypal.com
# PAYPAL_WEBHOOK_ID: ID del webhook registrado en PayPal Developer → Webhooks
PAYPAL_CLIENT_ID="Axxxxxxxxxxxxx"
PAYPAL_CLIENT_SECRET="Exxxxxxxxxxxxx"
PAYPAL_WEBHOOK_ID="WH-xxxxxxxxxxxx"
# sandbox | production
PAYPAL_ENV="sandbox"
