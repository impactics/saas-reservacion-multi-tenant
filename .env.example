# -----------------------------------------------------------------
# BASE DE DATOS — Neon PostgreSQL
# -----------------------------------------------------------------
# Obtener en: https://console.neon.tech → Connection string
# Usar la URL del pooler (puerto 6543) con pgbouncer=true para
# compatibilidad con Prisma en entornos serverless (Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?sslmode=require&pgbouncer=true"


# -----------------------------------------------------------------
# APP
# -----------------------------------------------------------------
# URL pública de la app (sin slash final)
# Desarrollo: http://localhost:3000
# Producción: https://tudominio.com
NEXT_PUBLIC_APP_URL="https://tudominio.com"


# -----------------------------------------------------------------
# AUTENTICACIÓN ADMIN — NextAuth / Auth.js
# -----------------------------------------------------------------
# URL base de la app — requerida por NextAuth para construir callbacks
# En Vercel puede omitirse (usa VERCEL_URL automáticamente)
NEXTAUTH_URL="https://tudominio.com"

# Secret criptográfico para firmar/verificar JWT de sesión
# Generar con: openssl rand -base64 32
# ⚠️  Sin este valor la app lanza un error al arrancar. Mínimo 32 caracteres.
NEXTAUTH_SECRET=""

# Emails con acceso de superadmin separados por coma
# Ejemplo: admin@tudominio.com,otro@tudominio.com
ADMIN_EMAILS=""

# Hash bcrypt de la contraseña del superadmin para login por credenciales
# Generar con: node -e "require('bcryptjs').hash('TuContraseña',12).then(console.log)"
# ⚠️  Almacenar el HASH, NUNCA la contraseña en texto plano
SUPERADMIN_PASSWORD=""

# Provider Google OAuth para login del panel admin
# Crear en: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Redirect URI autorizado: https://tudominio.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""


# -----------------------------------------------------------------
# CORS — Orígenes permitidos para la API pública
# -----------------------------------------------------------------
# Lista de orígenes autorizados separados por coma (sin slash final)
# Ejemplo: https://mi-ecommerce.com,https://admin.mi-ecommerce.com
# ⚠️  Si está vacío, TODOS los cross-origin requests serán bloqueados
ALLOWED_ORIGINS="https://tudominio.com"


# -----------------------------------------------------------------
# UPSTASH REDIS — Rate limiting y caché
# -----------------------------------------------------------------
# Crear instancia en: https://console.upstash.com
# Requerido por Redis.fromEnv() — ambas variables deben estar presentes
UPSTASH_REDIS_REST_URL="https://YOUR_REDIS.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""


# -----------------------------------------------------------------
# UPSTASH QSTASH — Cola de jobs asíncronos
# -----------------------------------------------------------------
# Obtener en: https://console.upstash.com → QStash → API Keys
QSTASH_TOKEN=""
# Obtener en: https://console.upstash.com → QStash → Signing Keys
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""


# -----------------------------------------------------------------
# GOOGLE OAUTH2 — Google Calendar (por organización)
# -----------------------------------------------------------------
# Crear en: https://console.cloud.google.com → APIs → Credentials
# Scopes requeridos: calendar.events, calendar.readonly
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Redirect URI registrado en GCP para el flujo de conexión del calendario
GOOGLE_REDIRECT_URI="https://tudominio.com/api/auth/google/callback"

# Token de verificación para el webhook push de Google Calendar
# Generar con: openssl rand -hex 32
# Registrar al crear el canal push en Google Calendar API
GOOGLE_CALENDAR_WEBHOOK_TOKEN=""


# -----------------------------------------------------------------
# WHATSAPP — Meta Business API (Cloud API)
# -----------------------------------------------------------------
# Obtener PHONE_NUMBER_ID en: Meta for Developers → WhatsApp → Getting Started
WHATSAPP_API_URL="https://graph.facebook.com/v19.0/PHONE_NUMBER_ID/messages"
# Usar token de acceso permanente del sistema (no el token temporal de 24h)
WHATSAPP_API_TOKEN=""
# Número de WhatsApp Business en formato internacional (ej: 593XXXXXXXXX)
WHATSAPP_FROM_NUMBER=""


# -----------------------------------------------------------------
# EMAIL — Resend
# -----------------------------------------------------------------
# Crear API key en: https://resend.com → API Keys
RESEND_API_KEY=""
# Dirección remitente verificada en Resend (debe coincidir con dominio verificado)
EMAIL_FROM="Clínica <noreply@tudominio.com>"


# -----------------------------------------------------------------
# PAGOS
# -----------------------------------------------------------------
# Proveedores activos: payphone | paypal
PAYMENT_PROVIDER="payphone"
# Mismo valor expuesto al cliente para el formulario de checkout
NEXT_PUBLIC_PAYMENT_PROVIDER="payphone"


# ── Payphone (Ecuador) ───────────────────────────────────────
# Portal: https://appstore.payphonetodoesposible.com
# Token completo con prefijo Bearer incluido
PAYPHONE_APP_ID="Bearer_xxxxx"
# Token de firma para verificar callbacks del webhook Payphone
# Generar con: openssl rand -hex 32
# Registrar en el portal Payphone como "Token de verificación"
PAYPHONE_TOKEN=""


# ── PayPal ─────────────────────────────────────────────────────
# Developer: https://developer.paypal.com
PAYPAL_CLIENT_ID="Axxxxxxxxxxxxx"
PAYPAL_CLIENT_SECRET="Exxxxxxxxxxxxx"
# ID del webhook registrado en PayPal Developer → My Apps → Webhooks
PAYPAL_WEBHOOK_ID="WH-xxxxxxxxxxxx"
# Entorno: sandbox | production
PAYPAL_ENV="sandbox"
